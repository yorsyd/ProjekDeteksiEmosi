34:13.571047Z"}},"outputs":[],"execution_count":2},{"cell_type":"markdown","source":"# EDA","metadata":{}},{"cell_type":"code","source":"# Load a sample image \n# using open() to open images\nimage_data = Image.open(train_angry_img_path+'/im0.png')\nimage_data","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:34:13.572921Z","iopub.execute_input":"2026-04-20T03:34:13.573330Z","iopub.status.idle":"2026-04-20T03:34:13.648205Z","shell.execute_reply.started":"2026-04-20T03:34:13.573292Z","shell.execute_reply":"2026-04-20T03:34:13.647405Z"}},"outputs":[{"execution_count":3,"output_type":"execute_result","data":{"text/plain":"<PIL.PngImagePlugin.PngImageFile image mode=L size=48x48>","image/png":"\n","image/jpeg":"\n"},"metadata":{}}],"execution_count":3},{"cell_type":"code","source":"# Get the shape of the image\nimage=plt.imread(train_angry_img_path+'/im0.png')\nprint(f'Image shape: {image.shape}')\n\n# Convert image data (like jpeg) to numpy using asarray()\nimage_array = npy.asarray(image_data)\nprint(f'Image data array: {image_array}')\n\n# Get the shape of the image array\nprint(f'Image array shape: {image_array.shape}')\n\n# Printing the image \nplt.imshow(image_array)\nplt.xlabel('Width')\nplt.ylabel('Height')\nplt.title('An Angry Face')\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:34:13.649282Z","iopub.execute_input":"2026-04-20T03:34:13.649883Z","iopub.status.idle":"2026-04-20T03:34:13.772447Z","shell.execute_reply.started":"2026-04-20T03:34:13.649858Z","shell.execute_reply":"2026-04-20T03:34:13.771832Z"}},"outputs":[{"name":"stdout","text":"Image shape: (48, 48)\nImage data array: [[ 70  80  82 ...  52  43  41]\n [ 65  61  58 ...  56  52  44]\n [ 50  43  54 ...  49  56  47]\n ...\n [ 91  65  42 ...  72  56  43]\n [ 77  82  79 ... 105  70  46]\n [ 77  72  84 ... 106 109  82]]\nImage array shape: (48, 48)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 640x480 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":4},{"cell_type":"code","source":"# Get the list of folders in the directory as classes\nclasses=os.listdir(TRAIN_PATH+'/')\nclasses","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:34:13.773244Z","iopub.execute_input":"2026-04-20T03:34:13.773512Z","iopub.status.idle":"2026-04-20T03:34:13.781656Z","shell.execute_reply.started":"2026-04-20T03:34:13.773479Z","shell.execute_reply":"2026-04-20T03:34:13.780928Z"}},"outputs":[{"execution_count":5,"output_type":"execute_result","data":{"text/plain":"['fearful', 'disgusted', 'angry', 'neutral', 'sad', 'surprised', 'happy']"},"metadata":{}}],"execution_count":5},{"cell_type":"code","source":"# Get dictionary list of image count per class\ndef class_sample(type):\n    if type.lower() == 'test' or type.lower() == 'train':\n        path=''\n        if type.lower() == 'train':    \n            path= TRAIN_PATH\n        else:\n            path= TEST_PATH\n        \n        filepath=path+'/'\n        class_count = []\n        class_dict ={}\n        for folder in os.listdir(filepath) :\n              class_count.append(len(os.listdir(filepath+folder)))\n              class_dict[folder]=len(os.listdir(filepath+folder))\n        class_total = sum(class_count)\n        return class_total, class_count, class_dict\n    else:\n        raise ValueError('Invalid type. Must be \"test\" or \"train\".')\n\n\ndef test_train_distribution():\n      print(\"---- Train Set ----\")\n      avg_train=class_sample('train')[0]/len(class_sample('train')[1])\n      print(f'Train class distribution:\\n{class_sample(\"train\")[2]}')\n      print(\"Average train class: \",round(avg_train))    \n      print('Total train: ', class_sample('train')[0])\n\n      print(\"\\n---- Test Set ----\")\n      avg_test=class_sample('test')[0]/len(class_sample('test')[1])\n      print(f'Test class distribution:\\n{class_sample(\"test\")[2]}')\n      print(\"Average test class: \",round(avg_test)) \n      print('Total test: ', class_sample('test')[0])\n\n\ntest_train_distribution()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:34:13.782598Z","iopub.execute_input":"2026-04-20T03:34:13.782950Z","iopub.status.idle":"2026-04-20T03:34:14.466389Z","shell.execute_reply.started":"2026-04-20T03:34:13.782918Z","shell.execute_reply":"2026-04-20T03:34:14.465770Z"}},"outputs":[{"name":"stdout","text":"---- Train Set ----\nTrain class distribution:\n{'fearful': 4097, 'disgusted': 436, 'angry': 3995, 'neutral': 4965, 'sad': 4830, 'surprised': 3171, 'happy': 7215}\nAverage train class:  4101\nTotal train:  28709\n\n---- Test Set ----\nTest class distribution:\n{'fearful': 1024, 'disgusted': 111, 'angry': 958, 'neutral': 1233, 'sad': 1247, 'surprised': 831, 'happy': 1774}\nAverage test class:  1025\nTotal test:  7178\n","output_type":"stream"}],"execution_count":6},{"cell_type":"markdown","source":"# Data Preprocessing","metadata":{}},{"cell_type":"markdown","source":"## Oversampling","metadata":{}},{"cell_type":"code","source":"# Oversampling Technique\nimport os\nfrom PIL import Image\n\n# Define the paths to the original and oversampled dataset\ntrain_dir = TRAIN_PATH\noversampled_dir = OVERSAMPLED_TRAIN_PATH\n\ntarget_length = 7215 # highest count in a class\n# target_length = 4101 Average\n\nif not os.path.exists(oversampled_dir):\n    os.mkdir(oversampled_dir)\n\nfor subfolder in os.listdir(train_dir):\n    subfolder_path = os.path.join(train_dir, subfolder)\n    if os.path.isdir(subfolder_path):\n        num_images = len(os.listdir(subfolder_path))\n        num_duplicates = target_length // num_images\n        remainder = target_length % num_images\n\n        for i in range(num_duplicates):\n            for image_file in os.listdir(subfolder_path):\n                image_path = os.path.join(subfolder_path, image_file)\n                image = Image.open(image_path)\n                new_image_file = f\"{i}_{image_file}\"\n                new_image_path = os.path.join(oversampled_dir, subfolder, new_image_file)\n                if not os.path.exists(os.path.join(oversampled_dir, subfolder)):\n                    os.mkdir(os.path.join(oversampled_dir, subfolder))\n                image.save(new_image_path)\n\n        if remainder != 0:\n            for image_file in os.listdir(subfolder_path)[:remainder]:\n                image_path = os.path.join(subfolder_path, image_file)\n                image = Image.open(image_path)\n                new_image_file = f\"{num_duplicates}_{image_file}\"\n                new_image_path = os.path.join(oversampled_dir, subfolder, new_image_file)\n                if not os.path.exists(os.path.join(oversampled_dir, subfolder)):\n                    os.mkdir(os.path.join(oversampled_dir, subfolder))\n                image.save(new_image_path)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:34:14.468299Z","iopub.execute_input":"2026-04-20T03:34:14.468558Z","iopub.status.idle":"2026-04-20T03:37:09.022917Z","shell.execute_reply.started":"2026-04-20T03:34:14.468536Z","shell.execute_reply":"2026-04-20T03:37:09.022229Z"}},"outputs":[],"execution_count":7},{"cell_type":"code","source":"# Get dictionary list of image count per class\ndef over_class_sample():\n        filepath=OVERSAMPLED_TRAIN_PATH+'/'\n        class_count = []\n        class_dict ={}\n        for folder in os.listdir(filepath) :\n              class_count.append(len(os.listdir(filepath+folder)))\n              class_dict[folder]=len(os.listdir(filepath+folder))\n        class_total = sum(class_count)\n        return class_total, class_count, class_dict","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:37:09.023801Z","iopub.execute_input":"2026-04-20T03:37:09.024069Z","iopub.status.idle":"2026-04-20T03:37:09.028903Z","shell.execute_reply.started":"2026-04-20T03:37:09.024034Z","shell.execute_reply":"2026-04-20T03:37:09.028164Z"}},"outputs":[],"execution_count":8},{"cell_type":"code","source":"def test_train_distribution():\n      print(\"\\n---- Oversampled Train Set ----\")\n      avg_train=over_class_sample()[0]/len(over_class_sample()[1])\n      print(f'Train class distribution:\\n{over_class_sample()[2]}')\n      print(\"Average train class: \",round(avg_train))    \n      print('Total train: ', over_class_sample()[0])\n\n\n\ntest_train_distribution()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:37:09.029867Z","iopub.execute_input":"2026-04-20T03:37:09.030342Z","iopub.status.idle":"2026-04-20T03:37:09.231820Z","shell.execute_reply.started":"2026-04-20T03:37:09.030306Z","shell.execute_reply":"2026-04-20T03:37:09.231078Z"}},"outputs":[{"name":"stdout","text":"\n---- Oversampled Train Set ----\nTrain class distribution:\n{'surprised': 7215, 'angry': 7215, 'happy': 7215, 'sad': 7215, 'disgusted': 7215, 'fearful': 7215, 'neutral': 7215}\nAverage train class:  7215\nTotal train:  50505\n","output_type":"stream"}],"execution_count":9},{"cell_type":"markdown","source":"## Data Augmentation","metadata":{}},{"cell_type":"code","source":"target_size=(48, 48)\n# target_size=(224, 224)\nbatch_size=32\n\n## Train Image Data Generator instance. \n# We will not apply any transformon specific orientations or features and no initial rescale to the image\n# We'll only split the image data into train and validation set\ntrainValidation_data_generator = ImgDataGen(\n                                    rescale=1./255,  # Gunakan 255, bukan 225\n                                    rotation_range=10,\n                                    zoom_range=0.2,\n                                    width_shift_range=0.1,\n                                    height_shift_range=0.1,\n                                    shear_range=0.2,\n                                    horizontal_flip=True,\n                                    fill_mode='nearest',\n                                    validation_split=0.2\n)\n\n\n# Test Image Data Generator instance for Test data\ntest_data_generator = ImgDataGen(\n                                rescale = 1./255,\n                                )\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:37:09.232879Z","iopub.execute_input":"2026-04-20T03:37:09.233444Z","iopub.status.idle":"2026-04-20T03:37:09.237765Z","shell.execute_reply.started":"2026-04-20T03:37:09.233419Z","shell.execute_reply":"2026-04-20T03:37:09.237050Z"}},"outputs":[],"execution_count":10},{"cell_type":"markdown","source":"# Data Generator","metadata":{}},{"cell_type":"code","source":"## Mapping images to their classes.\nprint('Train Set Generated - ',end=' ') \ntrain_generator = trainValidation_data_generator.flow_from_directory(\n                                                            directory=OVERSAMPLED_TRAIN_PATH, \n                                                            # directory=TRAIN_PATH, \n                                                            target_size=target_size,\n                                                            batch_size=batch_size,\n                                                            class_mode='categorical', \n                                                            color_mode='rgb', \n                                                            classes=classes,\n                                                            shuffle=True, \n                                                            subset='training' # set as training data\n                                                        )\n## Mapping images to their classes.\nprint('Validation Set Generated - ',end=' ') \nvalidation_generator = trainValidation_data_generator.flow_from_directory(\n                                                            # directory=TRAIN_PATH, \n                                                            directory=OVERSAMPLED_TRAIN_PATH, \n                                                            target_size=target_size,\n                                                            batch_size=batch_size,\n                                                            class_mode='categorical', \n                                                            color_mode='rgb', \n                                                            classes= classes,\n                                                            shuffle=False, \n                                                            subset='validation' # set as validation data\n                                                        )\ntest_samples=class_sample('test')[0]\ntest_batch_size=batch_size\ntest_steps=int(test_samples/test_batch_size)\n\n## Mapping images to their classes.\nprint('Test Set Generated - ',end=' ') \ntest_generator = test_data_generator.flow_from_directory(\n                                        directory=TEST_PATH, \n                                        target_size=target_size,\n                                        class_mode='categorical', \n                                        color_mode='rgb', \n                                        classes=classes,\n                                        shuffle=False, \n                                        batch_size=test_batch_size\n                                        )\n\n## Mapping shuffled images to their classes.\nprint('Shuffled Test Set Generated - ',end=' ') \ntest_generator_shuffled = test_data_generator.flow_from_directory(\n                                        TEST_PATH, \n                                        target_size=target_size,\n                                        class_mode='categorical', \n                                        color_mode='rgb', \n                                        classes=classes,\n                                        shuffle=True, \n                                        batch_size=test_batch_size\n                                        )","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:37:09.238672Z","iopub.execute_input":"2026-04-20T03:37:09.238952Z","iopub.status.idle":"2026-04-20T03:37:20.465850Z","shell.execute_reply.started":"2026-04-20T03:37:09.238922Z","shell.execute_reply":"2026-04-20T03:37:20.465159Z"}},"outputs":[{"name":"stdout","text":"Train Set Generated -  Found 40404 images belonging to 7 classes.\nValidation Set Generated -  Found 10101 images belonging to 7 classes.\nTest Set Generated -  Found 7178 images belonging to 7 classes.\nShuffled Test Set Generated -  Found 7178 images belonging to 7 classes.\n","output_type":"stream"}],"execution_count":11},{"cell_type":"code","source":"# From the generator we can get information we will need later\n# classes=  # os.listdir(TRAIN_PATH+'/')\nclass_dictionary = train_generator.class_indices\nclass_keys = list(train_generator.class_indices.keys())\nclass_values = list(train_generator.class_indices.values())\nclass_count = len(class_keys)\n\nprint ('test batch size: ' ,test_batch_size, '  test steps: ', test_steps, ' number of classes : ', class_count)\n\ntrain_images, train_labels = next(train_generator)\nvalidation_images, validation_labels = next(validation_generator)\ntest_images, test_labels = next(test_generator)\n\nprint(f'\\nThere are 7 classes: {classes}')\nprint(f'The class dictionary are: {class_dictionary}')\nprint('Class count: ', class_count)\n\nprint('\\nX_train shape: ', train_images.shape)\nprint('y_train shape: ', train_labels.shape)\nprint('\\nX_test shape: ', test_images.shape)\nprint('y_test shape: ', test_labels.shape)\n\nprint('\\ntrain_generator sample: ', train_generator.samples)\nprint('validation_generator sample: ', validation_generator.samples)\nprint('test_generator sample: ', test_generator.samples)\n\nprint('\\ntrain_generator sample: ', train_generator.labels)\nprint('validation_generator sample: ', validation_generator.labels)\nprint('test_generator sample: ', test_generator.labels)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:37:20.466962Z","iopub.execute_input":"2026-04-20T03:37:20.467248Z","iopub.status.idle":"2026-04-20T03:37:20.657331Z","shell.execute_reply.started":"2026-04-20T03:37:20.467216Z","shell.execute_reply":"2026-04-20T03:37:20.656568Z"}},"outputs":[{"name":"stdout","text":"test batch size:  32   test steps:  224  number of classes :  7\n\nThere are 7 classes: ['fearful', 'disgusted', 'angry', 'neutral', 'sad', 'surprised', 'happy']\nThe class dictionary are: {'fearful': 0, 'disgusted': 1, 'angry': 2, 'neutral': 3, 'sad': 4, 'surprised': 5, 'happy': 6}\nClass count:  7\n\nX_train shape:  (32, 48, 48, 3)\ny_train shape:  (32, 7)\n\nX_test shape:  (32, 48, 48, 3)\ny_test shape:  (32, 7)\n\ntrain_generator sample:  40404\nvalidation_generator sample:  10101\ntest_generator sample:  7178\n\ntrain_generator sample:  [0 0 0 ... 6 6 6]\nvalidation_generator sample:  [0 0 0 ... 6 6 6]\ntest_generator sample:  [0 0 0 ... 6 6 6]\n","output_type":"stream"}],"execution_count":12},{"cell_type":"code","source":"class_indices = train_generator.class_indices\nclass_counts = {class_name: 0 for class_name in class_indices}\nnum_images = train_generator.samples\n\nbatch_size = train_generator.batch_size\nnum_batches = len(train_generator)\n\nfor i in range(num_batches):\n    batch = next(train_generator)\n    images, labels = batch\n    for j in range(len(labels)):\n        label = npy.argmax(labels[j])  # convert one-hot encoding to integer label\n        class_name = list(class_indices.keys())[list(class_indices.values()).index(label)]\n        class_counts[class_name] += 1\n\nprint(class_counts)\nprint(f\"Total number of images in train generator: {num_images}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:37:20.658324Z","iopub.execute_input":"2026-04-20T03:37:20.658615Z","iopub.status.idle":"2026-04-20T03:38:00.022798Z","shell.execute_reply.started":"2026-04-20T03:37:20.658576Z","shell.execute_reply":"2026-04-20T03:38:00.022112Z"}},"outputs":[{"name":"stdout","text":"{'fearful': 5767, 'disgusted': 5765, 'angry': 5774, 'neutral': 5770, 'sad': 5775, 'surprised': 5777, 'happy': 5776}\nTotal number of images in train generator: 40404\n","output_type":"stream"}],"execution_count":13},{"cell_type":"markdown","source":"# Visual","metadata":{}},{"cell_type":"code","source":"import numpy as np","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:38:00.023846Z","iopub.execute_input":"2026-04-20T03:38:00.024120Z","iopub.status.idle":"2026-04-20T03:38:00.027519Z","shell.execute_reply.started":"2026-04-20T03:38:00.024098Z","shell.execute_reply":"2026-04-20T03:38:00.026775Z"}},"outputs":[],"execution_count":14},{"cell_type":"code","source":"# Get the sample images, labels, and their filenames \n# To get the correct filename, turn off the shuffle\ndef plotImageWithNames(gen):\n    images, labels = next(gen)\n    classes = list(gen.class_indices.keys())\n    \n    plt.figure(figsize=(20, 30))\n    length = len(labels)\n    r = min(length, 32) # Menggunakan min() lebih simpel daripada if-else\n    \n    for i in range(r):        \n        plt.subplot(7, 5, i + 1)\n        \n        # PERBAIKAN: Gunakan image langsung tanpa dibagi 255 lagi\n        # karena generator sudah melakukan rescaling\n        image = images[i] \n        \n        # Jika gambar terlihat terlalu gelap/aneh karena floating point, \n        # kamu bisa memastikan nilainya klip di rentang 0-1\n        image = np.clip(image, 0, 1)\n        \n        plt.imshow(image)\n        \n        index = np.argmax(labels[i])\n        class_name = classes[index]\n        \n        plt.title(\n            label=f\"{class_name}\", \n            color='blue', \n            fontsize=20\n        )\n        plt.axis('off')\n    plt.show()\n\nplotImageWithNames(train_generator)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:38:00.028453Z","iopub.execute_input":"2026-04-20T03:38:00.028706Z","iopub.status.idle":"2026-04-20T03:38:01.458679Z","shell.execute_reply.started":"2026-04-20T03:38:00.028673Z","shell.execute_reply":"2026-04-20T03:38:01.457897Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 2000x3000 with 32 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":15},{"cell_type":"markdown","source":"# Modeling","metadata":{}},{"cell_type":"code","source":"# Model Architecture path\ndef model_arch(model_name):\n    # !mkdir -p images\n    !mkdir images\n    arch=IMAGE_PATH+'/fer-2013_'+model_name+'.png'\n    return arch\n\n#  TensorFlow Checkpoint save_weight uses .ckpt extension format\ndef checkpoint_path(model_name):\n    # !mkdir models\n    checkpoint_path = MODEL_PATH+\"/fedav_best_model-\"+model_name+\".ckpt\"\n    return checkpoint_path\n\nmodel_name = \"MobileNet-EmotionDetection\"","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:38:01.459685Z","iopub.execute_input":"2026-04-20T03:38:01.460161Z","iopub.status.idle":"2026-04-20T03:38:01.464722Z","shell.execute_reply.started":"2026-04-20T03:38:01.460136Z","shell.execute_reply":"2026-04-20T03:38:01.464016Z"}},"outputs":[],"execution_count":16},{"cell_type":"code","source":"from tensorflow.keras.callbacks import ModelCheckpoint, ReduceLROnPlateau, EarlyStopping\n\n# 1. ModelCheckpoint (Asuransi penyimpanan)\ncheckpoint = ModelCheckpoint(\n    'best_emotion_model_mobilenet.keras',\n    monitor='val_accuracy',\n    save_best_only=True,\n    verbose=1\n)\n\n# 2. ReduceLROnPlateau (Menurunkan kecepatan belajar jika stagnan)\nlr_scheduler = ReduceLROnPlateau(\n    monitor='val_loss',\n    factor=0.2,\n    patience=3,      # Jika loss tidak turun selama 3 epoch, LR diturunkan\n    min_lr=0.000001,\n    verbose=1\n)\n\n# 3. EarlyStopping (Rem otomatis)\nearly_stop = EarlyStopping(\n    monitor='val_loss', \n    patience=7,       # Jika dalam 7 epoch tidak ada perbaikan loss, stop training\n    restore_best_weights=True, # Otomatis kembali ke bobot terbaik sebelum berhenti\n    verbose=1\n)\n\n# Gabungkan semuanya\ncallbacks_list = [checkpoint, lr_scheduler, early_stop]","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:38:01.465516Z","iopub.execute_input":"2026-04-20T03:38:01.465769Z","iopub.status.idle":"2026-04-20T03:38:01.477646Z","shell.execute_reply.started":"2026-04-20T03:38:01.465749Z","shell.execute_reply":"2026-04-20T03:38:01.477054Z"}},"outputs":[],"execution_count":17},{"cell_type":"code","source":"import tensorflow as tf\nfrom tensorflow.keras.applications import MobileNetV2\nfrom tensorflow.keras import layers, models\n\ndef build_mobilenet_emotion(input_shape=(48, 48, 3), num_classes=7):\n    # 1. Load Pre-trained Base Model\n    # include_top=False artinya kita buang layer klasifikasi aslinya\n    base_model = MobileNetV2(input_shape=input_shape,\n                             include_top=False,\n                             weights='imagenet')\n    \n    # Freeze base model agar bobot asli ImageNet tidak rusak di awal\n    base_model.trainable = False \n\n    model = models.Sequential([\n        base_model,\n        \n        # 2. Global Average Pooling (Mengurangi parameter agar ringan)\n        layers.GlobalAveragePooling2D(),\n        \n        # 3. Dense Layer Baru untuk Klasifikasi Emosi\n        layers.Dense(256, activation='relu'),\n        layers.BatchNormalization(),\n        layers.Dropout(0.4),\n        \n        layers.Dense(num_classes, activation='softmax')\n    ])\n    \n    return model","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:38:01.478407Z","iopub.execute_input":"2026-04-20T03:38:01.478838Z","iopub.status.idle":"2026-04-20T03:38:01.491095Z","shell.execute_reply.started":"2026-04-20T03:38:01.478806Z","shell.execute_reply":"2026-04-20T03:38:01.490494Z"}},"outputs":[],"execution_count":18},{"cell_type":"code","source":"# Cell ini untuk pelatihan awal\nmodel_mobile = build_mobilenet_emotion(input_shape=(48, 48, 3), num_classes=len(classes))\n\nmodel_mobile.compile(\n    optimizer=tf.keras.optimizers.Adam(learning_rate=0.001), # Kecepatan belajar standar\n    loss='categorical_crossentropy',\n    metrics=['accuracy']\n)\n\n# Training tahap pertama (10-20 epoch)\n# Pastikan base_model.trainable = False di dalam fungsi build_mobilenet_emotion\nhistory_awal = model_mobile.fit(\n    train_generator,\n    epochs=20,\n    validation_data=validation_generator,\n    callbacks=callbacks_list\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T03:43:37.805260Z","iopub.execute_input":"2026-04-20T03:43:37.805887Z","iopub.status.idle":"2026-04-20T04:02:59.231736Z","shell.execute_reply.started":"2026-04-20T03:43:37.805857Z","shell.execute_reply":"2026-04-20T04:02:59.230876Z"}},"outputs":[{"name":"stderr","text":"/tmp/ipykernel_55/2423637572.py:8: UserWarning: `input_shape` is undefined or non-square, or `rows` is not in [96, 128, 160, 192, 224]. Weights for input shape (224, 224) will be loaded as the default.\n  base_model = MobileNetV2(input_shape=input_shape,\n","output_type":"stream"},{"name":"stdout","text":"Epoch 1/20\n","output_type":"stream"},{"name":"stderr","text":"/usr/local/lib/python3.12/dist-packages/keras/src/trainers/data_adapters/py_dataset_adapter.py:121: UserWarning: Your `PyDataset` class should call `super().__init__(**kwargs)` in its constructor. `**kwargs` can include `workers`, `use_multiprocessing`, `max_queue_size`. Do not pass these arguments to `fit()`, as they will be ignored.\n  self._warn_if_super_not_called()\nWARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nI0000 00:00:1776656623.396418     154 service.cc:152] XLA service 0x7e5bfc011eb0 initialized for platform CUDA (this does not guarantee that XLA will be used). Devices:\nI0000 00:00:1776656623.396478     154 service.cc:160]   StreamExecutor device (0): Tesla P100-PCIE-16GB, Compute Capability 6.0\nI0000 00:00:1776656624.52